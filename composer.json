{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "sinemacula/laravel-authentication",
    "type": "library",
    "description": "Stateless contextual authentication primitives (Identity, Principal, Device, Tenant) for Laravel 12 and 13.",
    "keywords": [
        "sine macula",
        "laravel",
        "auth",
        "authentication"
    ],
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Ben Carey",
            "email": "bdmc@sinemacula.co.uk"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-mbstring": "*",
        "laravel/framework": "^12.40|^13.3"
    },
    "require-dev": {
        "brianium/paratest": "^7.20",
        "doctrine/coding-standard": "^14.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "infection/infection": "^0.32.6",
        "larastan/larastan": "^3.9",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.2|^11.0",
        "phpbench/phpbench": "^1.6.1",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpdoc-parser": "^2.3",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.5",
        "sinemacula/coding-standards": "^1.0",
        "slevomat/coding-standard": "^8.28",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "SineMacula\\Laravel\\Authentication\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Benchmarks\\": "benchmarks/",
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "check": [
            "qlty check"
        ],
        "format": [
            "qlty fmt"
        ],
        "test": [
            "@php vendor/bin/paratest"
        ],
        "test:coverage": [
            "@php vendor/bin/paratest --coverage-clover=clover.xml"
        ],
        "test:unit": [
            "@php vendor/bin/paratest --testsuite Unit"
        ],
        "test:unit:coverage": [
            "@php vendor/bin/paratest --testsuite Unit --coverage-clover=clover.xml"
        ],
        "test:feature": [
            "@php vendor/bin/paratest --testsuite Feature"
        ],
        "test:feature:coverage": [
            "@php vendor/bin/paratest --testsuite Feature --coverage-clover=clover.xml"
        ],
        "test:integration": [
            "@php vendor/bin/paratest --testsuite Integration"
        ],
        "test:integration:coverage": [
            "@php vendor/bin/paratest --testsuite Integration --coverage-clover=clover.xml"
        ],
        "test:performance": [
            "@php vendor/bin/phpunit --testsuite Performance"
        ],
        "test:performance:coverage": [
            "@php vendor/bin/phpunit --testsuite Performance --coverage-clover=clover.xml"
        ],
        "test:mutation": [
            "@php vendor/bin/infection --configuration=infection.json5 --test-framework-options=\"--do-not-fail-on-warning --do-not-fail-on-phpunit-warning\" --only-covering-test-cases --threads=max --git-diff-lines --git-diff-base=origin/master --map-source-class-to-test --min-msi=85 --min-covered-msi=90"
        ],
        "test:mutation:full": [
            "@php vendor/bin/infection --configuration=infection.full.json5 --test-framework-options=\"--do-not-fail-on-warning --do-not-fail-on-phpunit-warning\" --only-covering-test-cases --threads=max"
        ],
        "bench": [
            "@php vendor/bin/phpbench run benchmarks --config=phpbench.json --progress=plain --report=aggregate"
        ],
        "bench:ci": [
            "@php -r \"is_dir('build') || mkdir('build', 0777, true);\"",
            "@php vendor/bin/phpbench run benchmarks --config=phpbench.json --progress=plain --report=aggregate --dump-file=build/phpbench.xml"
        ]
    },
    "scripts-descriptions": {
        "check": "Run static analysis and lint checks via qlty.",
        "format": "Format codebase using qlty.",
        "test": "Run all PHPUnit test suites in parallel using Paratest.",
        "test:coverage": "Run all PHPUnit test suites with clover coverage report.",
        "test:unit": "Run the Unit test suite in parallel using Paratest.",
        "test:unit:coverage": "Run the Unit test suite with clover coverage report.",
        "test:feature": "Run the Feature test suite in parallel using Paratest.",
        "test:feature:coverage": "Run the Feature test suite with clover coverage report.",
        "test:integration": "Run the Integration test suite in parallel using Paratest.",
        "test:integration:coverage": "Run the Integration test suite with clover coverage report.",
        "test:performance": "Run the Performance test suite for query and write budget contracts.",
        "test:performance:coverage": "Run the Performance test suite with clover coverage report.",
        "test:mutation": "Run the scoped Infection mutation-testing gate for the highest-risk auth paths.",
        "test:mutation:full": "Run the full Infection mutation suite across src/ without MSI thresholds.",
        "bench": "Run PHPBench benchmarks for runtime and JWT hot paths.",
        "bench:ci": "Run PHPBench benchmarks and dump CI output for artifact upload."
    },
    "extra": {
        "laravel": {
            "providers": [
                "SineMacula\\Laravel\\Mfa\\MfaServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "infection/extension-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
